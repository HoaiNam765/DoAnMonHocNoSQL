PORT=5000

# Neo4j Aura: lấy từ file credentials tải về khi tạo instance
# Neo4j Desktop cục bộ: NEO4J_URI=bolt://localhost:7687
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password
# Tên database. Để trống -> dùng database mặc định của tài khoản (an toàn nhất).
# Aura thường đặt tên database trùng instance id; Neo4j Desktop mặc định là "neo4j".
# Kiểm tra bằng lệnh trong Neo4j Browser: SHOW DATABASES
NEO4J_DATABASE=
